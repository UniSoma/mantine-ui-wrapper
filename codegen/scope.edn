;; Generation scope, expressed per dimension as everything-minus-excludes.
;; Each dimension is EITHER an explicit name set (#{...}) OR
;; {:all true :exclude #{...}} = "every resolvable entry minus these excludes".
;;
;; :components — {:all true} covers every docgen entry exported by a wrapped
;;   @mantine/* package (core, notifications, ...; never @mantine/hooks), minus
;;   :exclude. That is the whole @mantine/core surface today.
;; :hooks — {:all true} covers every use* export of the @mantine/hooks barrel.
;;   Non-hook barrel utilities (randomId, mergeRefs, ...) are already filtered out
;;   (they don't start with "use"). The excludes are the companion use* hooks that
;;   share another hook's docs page and so carry no description in hook-docs.edn
;;   (useFullscreenDocument/Element under use-fullscreen, useSessionStorage under
;;   use-local-storage, useMousePosition under use-mouse, etc.).
{:components {:all true :exclude #{}}
 :hooks {:all true
         :exclude #{"useCallbackRef"
                    "useFullscreenDocument"
                    "useFullscreenElement"
                    "useHorizontalCollapse"
                    "useMousePosition"
                    "useMutationObserverTarget"
                    "useSessionStorage"}}}
