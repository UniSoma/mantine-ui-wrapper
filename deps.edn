;; JVM-loadability surface for the shipped wrapper source (clj-kondo, cljdoc, JVM tests).
;; The browser build is driven by shadow-cljs.edn (standalone), not this file.
{:paths ["src/main"]
 :deps {org.clojure/clojure {:mvn/version "1.12.1"}}
 :aliases {:demo {:extra-paths ["demo"]}
           ;; Source-jar build + Clojars deploy (see build.clj, docs/release.md).
           :build {:extra-deps {io.github.clojure/tools.build {:mvn/version "0.10.14"}
                                slipset/deps-deploy {:mvn/version "0.2.5"}}
                   :ns-default build}}}
